# ==========================================
# Configurações do Supabase (Vercel / Local)
# ==========================================

# URL pública do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[ID-DO-PROJETO].supabase.co

# Chave anônima pública (pode ir para o navegador com segurança devido ao RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# String de conexão do Banco de Dados (NUNCA EXPONHA NO CLIENTE)
# Usado pelo Drizzle (Server Actions)
DATABASE_URL=postgresql://postgres.[ID-DO-PROJETO]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
